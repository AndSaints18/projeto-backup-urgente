<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/titulo_criar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nova Análise"
        android:textSize="24sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/titulo_criar"
        android:layout_above="@+id/menu_inferior"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:animateLayoutChanges="true">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Qual local você visitou?" android:textStyle="bold"/>
            <AutoCompleteTextView
                android:id="@+id/input_nome_local"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:inputType="textCapWords"
                android:hint="Ex: Ama Brownie..."
                android:completionThreshold="1"
                android:background="@android:drawable/editbox_background_normal"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/btn_sugerir_local"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Não encontrou? Recomende um novo local."
                android:textColor="#2196F3"
                android:textStyle="bold"
                android:paddingTop="4dp"
                android:paddingBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hora que foi:" android:textStyle="bold"/>
            <EditText android:id="@+id/input_hora" android:layout_width="match_parent" android:layout_height="50dp" android:inputType="time" android:hint="Ex: 19:30" android:layout_marginBottom="24dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nota Geral do Local:" android:textStyle="bold" android:textSize="18sp" android:textColor="#FF9800"/>
            <RatingBar android:id="@+id/rating_final" android:layout_width="wrap_content" android:layout_height="wrap_content" android:numStars="5" android:stepSize="0.5" android:progressTint="#FF9800" android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/btn_toggle_avaliacoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▼ Avaliar itens específicos (Opcional)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:padding="12dp"
                android:background="#E3F2FD"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:id="@+id/layout_avaliacoes_detalhadas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Atendimento:"/>
                <RatingBar android:id="@+id/rating_atendimento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:numStars="5" android:stepSize="1.0" android:scaleX="0.8" android:scaleY="0.8" android:transformPivotX="0dp" android:transformPivotY="0dp" android:layout_marginBottom="4dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Qualidade do Produto:"/>
                <RatingBar android:id="@+id/rating_qualidade" android:layout_width="wrap_content" android:layout_height="wrap_content" android:numStars="5" android:stepSize="1.0" android:scaleX="0.8" android:scaleY="0.8" android:transformPivotX="0dp" android:transformPivotY="0dp" android:layout_marginBottom="4dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ambiente e Atmosfera:"/>
                <RatingBar android:id="@+id/rating_ambiente" android:layout_width="wrap_content" android:layout_height="wrap_content" android:numStars="5" android:stepSize="1.0" android:scaleX="0.8" android:scaleY="0.8" android:transformPivotX="0dp" android:transformPivotY="0dp" android:layout_marginBottom="4dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Infraestrutura e Acessibilidade:"/>
                <RatingBar android:id="@+id/rating_infra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:numStars="5" android:stepSize="1.0" android:scaleX="0.8" android:scaleY="0.8" android:transformPivotX="0dp" android:transformPivotY="0dp" android:layout_marginBottom="4dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Custo-Benefício:"/>
                <RatingBar android:id="@+id/rating_custo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:numStars="5" android:stepSize="1.0" android:scaleX="0.8" android:scaleY="0.8" android:transformPivotX="0dp" android:transformPivotY="0dp" android:layout_marginBottom="16dp"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Observações / Comentário (Opcional):" android:textStyle="bold"/>
            <EditText android:id="@+id/input_observacoes" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="100dp" android:inputType="textMultiLine" android:gravity="top|start" android:padding="12dp" android:background="@android:drawable/editbox_background_normal" android:hint="Escreva sua experiência aqui..." android:layout_marginBottom="24dp"/>

            <Button android:id="@+id/btn_add_fotos" android:layout_width="match_parent" android:layout_height="50dp" android:text="📷 Adicionar Imagens (Opcional)" android:backgroundTint="#6C757D" android:layout_marginBottom="16dp"/>

            <Button android:id="@+id/btn_salvar_analise" android:layout_width="match_parent" android:layout_height="60dp" android:text="Salvar Análise" android:backgroundTint="#2196F3" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/menu_inferior"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <Button android:id="@+id/btn_menu_inicio" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Início" android:background="#00000000" android:textColor="#333333" />
        <Button android:id="@+id/btn_menu_add" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="+" android:textSize="24sp" android:textStyle="bold" android:background="#00000000" android:textColor="#2196F3" />
        <Button android:id="@+id/btn_menu_analises" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Meu Perfil" android:background="#00000000" android:textColor="#333333" android:textSize="12sp" />
    </LinearLayout>
</RelativeLayout>