<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_voltar_sugestao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="#757575"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sugerir Novo Local"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Conhece um lugar incrível que ainda não está no LocalReview? Conta pra gente!"
                android:textSize="15sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome do Local *"
                android:textStyle="bold"
                android:textColor="#212121"/>
            <EditText
                android:id="@+id/input_sugestao_nome"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:inputType="textCapWords"
                android:hint="Ex: Padaria do Seu Zé"
                android:background="@android:drawable/editbox_background_normal"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Que tipo de lugar é esse? (Opcional)"
                android:textStyle="bold"
                android:textColor="#212121"/>
            <EditText
                android:id="@+id/input_sugestao_tipo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:inputType="textCapWords"
                android:hint="Ex: Pizzaria, Parque, Bar..."
                android:background="@android:drawable/editbox_background_normal"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bairro ou Ponto de Referência (Opcional)"
                android:textStyle="bold"
                android:textColor="#212121"/>
            <EditText
                android:id="@+id/input_sugestao_bairro"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:inputType="textCapWords"
                android:hint="Ex: Perto da Praça X"
                android:background="@android:drawable/editbox_background_normal"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Por que devemos adicionar? (Opcional)"
                android:textStyle="bold"
                android:textColor="#212121"/>
            <EditText
                android:id="@+id/input_sugestao_motivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:padding="12dp"
                android:background="@android:drawable/editbox_background_normal"
                android:hint="O lanche lá é maravilhoso e..."
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btn_enviar_sugestao"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Enviar Sugestão"
                android:backgroundTint="#2196F3"
                android:textSize="16sp"
                android:textStyle="bold"
                android:elevation="2dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>