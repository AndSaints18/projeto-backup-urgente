<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <!-- Título Fixo no Topo -->
    <TextView
        android:id="@+id/titulo_home"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Locais Próximos"
        android:textSize="24sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp" />

    <!-- Área de Conteúdo (A lista rolável) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/titulo_home"
        android:layout_above="@+id/menu_inferior"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Mock 1: Bar do Zé -->
            <LinearLayout
                android:id="@+id/card_bar_do_ze"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bar do Zé"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nota: ⭐ 4.8"
                    android:textSize="14sp"
                    android:textColor="#FF9800"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distância: 1.2 km"
                    android:textSize="14sp"
                    android:textColor="#666666"/>
            </LinearLayout>

            <!-- Mock 2: Espetinho do João -->
            <LinearLayout
                android:id="@+id/card_espetinho_joao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Espetinho do João"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nota: ⭐ 4.5"
                    android:textSize="14sp"
                    android:textColor="#FF9800"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distância: 2.5 km"
                    android:textSize="14sp"
                    android:textColor="#666666"/>
            </LinearLayout>

            <!-- Mock 3: Boteco Central -->
            <LinearLayout
                android:id="@+id/card_boteco_central"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Boteco Central"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nota: ⭐ 4.2"
                    android:textSize="14sp"
                    android:textColor="#FF9800"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distância: 3.0 km"
                    android:textSize="14sp"
                    android:textColor="#666666"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- O Menu Inferior Pregado na Base -->
    <LinearLayout
        android:id="@+id/menu_inferior"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <Button
            android:id="@+id/btn_menu_inicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Início"
            android:background="#00000000"
            android:textColor="#2196F3"/>

        <Button
            android:id="@+id/btn_menu_add"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="+"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="#00000000"
            android:textColor="#ff6750a4"
            />

        <Button
            android:id="@+id/btn_menu_analises"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Meu Perfil"
            android:background="#00000000"
            android:textColor="#333333"
            android:textSize="12sp" />

    </LinearLayout>
</RelativeLayout>