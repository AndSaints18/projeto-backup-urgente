<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_voltar_ajuda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Voltar"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="#757575"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ajuda e Suporte"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Perguntas Frequentes (FAQ)"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:layout_marginBottom="16dp"
                android:paddingStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Qual é o objetivo do LocalReview?" android:textStyle="bold" android:textColor="#212121" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Somos uma plataforma colaborativa para você descobrir, avaliar e compartilhar suas experiências nos melhores locais, restaurantes e lanchonetes da região." android:textColor="#6C757D" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Como eu faço para avaliar um local?" android:textStyle="bold" android:textColor="#212121" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Basta clicar no botão '+' no menu inferior, buscar o local desejado na lista e deixar sua nota e comentário!" android:textColor="#6C757D" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Não encontrei o local que visitei. E agora?" android:textStyle="bold" android:textColor="#212121" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Na própria tela de criar análise, você verá um botão azul para 'Sugerir um novo local'. Nossa equipe analisará e adicionará o local em breve." android:textColor="#6C757D" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ainda precisa de ajuda?"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#212121"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_outra_duvida"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Sua dúvida é outra coisa?"
                android:backgroundTint="#2196F3"
                android:textSize="16sp"
                android:textStyle="bold"
                android:elevation="2dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>