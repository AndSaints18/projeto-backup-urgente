<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <!-- Barra Superior Fixa (Header) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_voltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:background="#00000000"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:textAllCaps="false"/>

    </LinearLayout>

    <!-- Área de Conteúdo Rolável -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Mock da Área de Fotos (Rolagem Horizontal Simples) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="#DDDDDD">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:layout_width="300dp"
                        android:layout_height="match_parent"
                        android:text="[ Foto Principal do Local ]"
                        android:gravity="center"
                        android:background="#BDBDBD"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="300dp"
                        android:layout_height="match_parent"
                        android:text="[ Foto do Cardápio / Ambiente ]"
                        android:gravity="center"
                        android:background="#9E9E9E"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Seção 1: Informações Principais -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/txt_nome_local"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bar do Zé"
                    android:textSize="26sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txt_categoria"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Categoria: Buteco / Espetinho"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/txt_nota_geral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 4.8 (Baseado em 12 análises)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"/>
            </LinearLayout>

            <!-- Seção 2: Descrição -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sobre o local"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/txt_descricao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Um dos butecos mais tradicionais perto da universidade. Famoso pelo espetinho de carne de sol com queijo coalho e a cerveja sempre trincando. Excelente custo-benefício para ir depois das aulas."
                    android:textSize="15sp"
                    android:textColor="#424242"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <!-- Seção 3: Avaliações dos Usuários -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avaliações Recentes"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Mock Avaliação 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Carlos Eduardo" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 5.0" android:textColor="#FF9800"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Atendimento rápido e o espetinho é sensacional!" android:textColor="#555555"/>
                </LinearLayout>

                <!-- Linha Divisória Simples -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="16dp"/>

                <!-- Mock Avaliação 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ana Silva" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 4.0" android:textColor="#FF9800"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Muito bom, mas achei que a música estava alta demais na sexta-feira." android:textColor="#555555"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>