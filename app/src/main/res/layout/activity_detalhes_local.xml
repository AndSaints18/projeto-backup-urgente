<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_voltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Voltar"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="#757575"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalhes do Local"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scrollbars="none"
                android:background="#DDDDDD">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:layout_width="300dp"
                        android:layout_height="match_parent"
                        android:text="[ Foto Principal do Local ]"
                        android:gravity="center"
                        android:background="#BDBDBD"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="300dp"
                        android:layout_height="match_parent"
                        android:text="[ Foto do Cardápio / Ambiente ]"
                        android:gravity="center"
                        android:background="#9E9E9E"/>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/txt_nome_local"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bar do Zé"
                    android:textSize="26sp"
                    android:textColor="#212121"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txt_categoria"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Categoria: Buteco / Espetinho"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/txt_nota_geral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 4.8 (Baseado em 12 análises)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btn_acao_favoritar"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="🤍 Favoritar"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:backgroundTint="#F1F3F5"
                        android:textColor="#495057"
                        android:elevation="0dp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btn_acao_mapa"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="📍 Como Chegar"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:backgroundTint="#E3F2FD"
                        android:textColor="#2196F3"
                        android:elevation="0dp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sobre o local"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/txt_descricao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descrição mockada."
                    android:textSize="15sp"
                    android:textColor="#6C757D"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avaliações Recentes"
                    android:textSize="18sp"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Carlos Eduardo" android:textStyle="bold" android:textColor="#212121"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 5.0" android:textColor="#FF9800" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Atendimento rápido e o lugar é sensacional!" android:textColor="#6C757D"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ana Silva" android:textStyle="bold" android:textColor="#212121"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 4.0" android:textColor="#FF9800" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Muito bom, mas achei que a música estava alta demais na sexta-feira." android:textColor="#6C757D"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_criar_avaliacao"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="✍️ Avaliar este local"
                    android:backgroundTint="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:elevation="2dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>