<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <!-- Botão Voltar Fixo no Topo (Fora do Scroll para estar sempre acessível) -->
    <Button
        android:id="@+id/btn_voltar_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Voltar"
        android:background="#00000000"
        android:textColor="#757575"
        android:textAllCaps="false"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Área Rolável para proteger contra a subida do teclado -->
    <!-- fillViewport="true" permite que o conteúdo ocupe a tela toda e centralize verticalmente -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/btn_voltar_login"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Bloco Central de Formulário -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Redefinir Senha"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:textColor="#212121"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Digite o código de 6 dígitos que enviamos para o seu e-mail e crie uma nova senha."
                android:textSize="14sp"
                android:textColor="#757575"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="32dp" />

            <!-- Campo Token -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código de Verificação (Token):"
                android:textStyle="bold"
                android:textColor="#212121"/>
            <EditText
                android:id="@+id/input_token"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:inputType="number"
                android:maxLength="6"
                android:hint="Ex: 123456"
                android:background="@android:drawable/editbox_background_normal"
                android:layout_marginBottom="16dp"/>

            <!-- Campo Nova Senha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nova Senha:"
                android:textStyle="bold"
                android:textColor="#212121"/>
            <EditText
                android:id="@+id/input_nova_senha"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:inputType="textPassword"
                android:background="@android:drawable/editbox_background_normal"
                android:layout_marginBottom="16dp"/>

            <!-- Campo Confirmar Senha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirmar Nova Senha:"
                android:textStyle="bold"
                android:textColor="#212121"/>
            <EditText
                android:id="@+id/input_confirma_senha"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:inputType="textPassword"
                android:background="@android:drawable/editbox_background_normal"
                android:layout_marginBottom="32dp"/>

            <!-- Botão Redefinir -->
            <Button
                android:id="@+id/btn_redefinir_senha"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Salvar nova senha"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#2196F3"
                android:elevation="4dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>