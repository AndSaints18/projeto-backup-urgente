<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <!-- Barra Superior Fixa (Header) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_voltar_minhas_analises"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:background="#00000000"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:textAllCaps="false"/>

    </LinearLayout>

    <!-- Área Rolável -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- animateLayoutChanges cria a animação suave do acordeão! -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:animateLayoutChanges="true"
            android:padding="16dp">

            <!-- Cabeçalho da Análise -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/txt_nome_local_analisado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome do Local"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txt_minha_nota_final"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minha Nota: ⭐ 5.0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- ACORDEÃO: Botão de Mostrar/Ocultar -->
            <TextView
                android:id="@+id/btn_toggle_notas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="▼ Ver notas detalhadas"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:padding="12dp"
                android:background="#E3F2FD"
                android:gravity="center"
                android:layout_marginBottom="2dp"/>

            <!-- ACORDEÃO: Conteúdo Oculto por padrão (visibility="gone") -->
            <LinearLayout
                android:id="@+id/layout_notas_detalhadas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <TextView android:id="@+id/txt_nota_atendimento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Atendimento: ⭐ 5.0" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/txt_nota_qualidade" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Qualidade: ⭐ 5.0" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/txt_nota_ambiente" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ambiente: ⭐ 4.0" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/txt_nota_infra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Infraestrutura: ⭐ 4.0" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/txt_nota_custo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Custo-Benefício: ⭐ 5.0"/>
            </LinearLayout>

            <!-- Meu Comentário -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meu Comentário"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/txt_meu_comentario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text='"Comentário mockado aqui."'
                    android:textSize="15sp"
                    android:textColor="#424242"
                    android:textStyle="italic"/>
            </LinearLayout>

            <!-- Minhas Fotos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fotos Enviadas"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="120dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                        <TextView android:layout_width="120dp" android:layout_height="match_parent" android:text="[ Foto 1 ]" android:gravity="center" android:background="#E0E0E0" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="120dp" android:layout_height="match_parent" android:text="[ Foto 2 ]" android:gravity="center" android:background="#E0E0E0"/>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>