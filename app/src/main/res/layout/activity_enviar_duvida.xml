<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_voltar_envio_duvida"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Voltar"
            android:background="?android:attr/selectableItemBackground"
            android:textColor="#757575"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fale Conosco"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Como podemos te ajudar hoje?"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descreva seu problema, dúvida ou sugestão abaixo. Nossa equipe responderá no e-mail cadastrado em breve."
                android:textSize="15sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp"/>

            <EditText
                android:id="@+id/input_duvida_texto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="200dp"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:padding="16dp"
                android:background="@android:drawable/editbox_background_normal"
                android:hint="Digite sua mensagem aqui..."
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btn_enviar_duvida_final"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Enviar Mensagem"
                android:backgroundTint="#2196F3"
                android:textSize="16sp"
                android:textStyle="bold"
                android:elevation="2dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>